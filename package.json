{
  "name": "nodejs-claude-code",
  "version": "0.1.0",
  "description": "A Node.js CLI AI programming assistant",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/types": "^7.29.0",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/babel__parser": "^7.0.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^3.23.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
